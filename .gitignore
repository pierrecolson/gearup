# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# gearup local-only data — JSON files are runtime state, not source. The app
# creates them lazily via store.ts ensureFile() / getSettings() fallback.
# Local seed lives in scripts/seed.mjs (`npm run seed`).
/data/*.json
/data/uploads/
/data/.cache/

# Personal progress/todo notes — kept locally, never pushed.
/PROGRESS.md
